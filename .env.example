# OpenAI API key
GPT_API_KEY=sk-proj-...

# PostgreSQL connection string
# Local: postgresql://<username>@localhost:5432/neubite
# Production: postgresql://neubite:<password>@<rds-endpoint>:5432/neubite
DATABASE_URL=postgresql://localhost:5432/neubite

# AWS Cognito (used to validate JWTs from the frontend)
COGNITO_USER_POOL_ID=us-east-2_xxxxxxxxx
COGNITO_REGION=us-east-2

# AWS infrastructure references (used for deployment scripts only, not required at runtime)
REPO_URI=<account-id>.dkr.ecr.<region>.amazonaws.com/neubite-backend
RDS_ENDPOINT=<rds-endpoint>
RDS_PASSWORD=<rds-master-password>
ALB_DNS_NAME=<alb-dns-name>
